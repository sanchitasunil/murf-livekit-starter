# =============================================================================
# Backend environment variables — copy to .env.local and fill in real values.
# =============================================================================

# -----------------------------------------------------------------------------
# LiveKit (real-time transport)
# Get these from https://cloud.livekit.io/ → your project → Settings
# -----------------------------------------------------------------------------
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key_here
LIVEKIT_API_SECRET=your_livekit_api_secret_here

# -----------------------------------------------------------------------------
# Murf (TTS — Text-to-Speech)
# Get your API key from https://murf.ai/api/dashboard
# -----------------------------------------------------------------------------
MURF_API_KEY=your_murf_api_key_here

# -----------------------------------------------------------------------------
# Deepgram (STT — Speech-to-Text)
# Get your API key from https://deepgram.com
# -----------------------------------------------------------------------------
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# -----------------------------------------------------------------------------
# LLM — use one of the following depending on which provider you use
# -----------------------------------------------------------------------------
# For Gemini (default): get from https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# For OpenAI: get from https://platform.openai.com/api-keys (if using OpenAI LLM)
# OPENAI_API_KEY=your_openai_api_key_here
