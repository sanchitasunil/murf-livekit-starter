# =============================================================================
# Frontend environment variables — copy to .env.local and fill in real values.
# =============================================================================

# -----------------------------------------------------------------------------
# LiveKit (real-time transport — must match your backend agent's LiveKit project)
# Get these from https://cloud.livekit.io/ → your project → Settings
# -----------------------------------------------------------------------------
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key_here
LIVEKIT_API_SECRET=your_livekit_api_secret_here

# -----------------------------------------------------------------------------
# Agent dispatch (optional)
# Leave blank for automatic dispatch; set to agent name for explicit dispatch.
# See https://docs.livekit.io/agents/server/agent-dispatch
# -----------------------------------------------------------------------------
AGENT_NAME=

# -----------------------------------------------------------------------------
# Optional — LiveKit Cloud Sandbox / custom app config
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_APP_CONFIG_ENDPOINT=
# SANDBOX_ID=
